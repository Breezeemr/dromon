{
  "$id": "https://schemas.ory.sh/presets/kratos/identity.email.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Person",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "minLength": 3
        },
        "fhirUser": {
          "type": "string",
          "title": "FHIR User ID (Patient, Practitioner, etc)"
        },
        "patientId": {
          "type": "string",
          "title": "Primary Patient ID"
        }
      },
      "required": [
        "email"
      ],
      "additionalProperties": false
    }
  }
}