{:paths ["bb/src"]
 :tasks
 {setup
  {:doc "Starts the local integration environment (Postgres, Kratos, Keto, Hydra) via Docker"
   :requires ([server.docker-env :as env])
   :task (if (every? env/container-running? ["ory-pg" "kratos" "keto" "hydra"])
           (println "Integration environment already running -- skipping setup.")
           (env/start!))}

  teardown
  {:doc "Stops and removes the local integration environment"
   :requires ([server.docker-env :as env])
   :task (if (not-any? env/container-exists? ["ory-pg" "kratos" "keto" "hydra"])
           (println "No integration containers found -- nothing to tear down.")
           (env/stop!))}

  tls-setup
  {:doc "Updates /etc/hosts to point fhir.local to 127.0.0.1 and generates a TLS dev certificate with mkcert."
   :task (let [domain    "fhir.local"
               keystore  (clojure.java.io/file "fhir-server/dev-keystore.p12")
               hosts-ok? (clojure.string/includes? (slurp "/etc/hosts") domain)]
           (if (and hosts-ok? (.exists keystore))
             (println "TLS already set up (hosts entry, dev-keystore.p12) -- skipping.")
             (do
               (if hosts-ok?
                 (println "Domain" domain "already in /etc/hosts.")
                 (do
                   (println "Adding" domain "to /etc/hosts (requires sudo)...")
                   (shell "sudo" "sh" "-c" (str "echo '127.0.0.1 " domain "' >> /etc/hosts"))))
               (if (.exists keystore)
                 (println "dev-keystore.p12 already exists, skipping mkcert.")
                 (do
                   (println "Generating dev certificate with mkcert...")
                   (shell "mkcert" "-install")
                   (shell "mkcert" "-pkcs12" "-p12-file" (.getPath keystore) domain))))))}

  inferno-setup
  {:doc "Clones the US Core Test Kit and runs its setup script to build docker images."
   :depends [tls-setup]
   :requires ([clj-yaml.core :as yaml])
   :task (let [compose-file "inferno-test-kit/docker-compose.yml"
               bg-file      "inferno-test-kit/docker-compose.background.yml"
               rootca-file  (clojure.java.io/file "inferno-test-kit/rootCA.pem")
               patched?     (fn [f]
                              (and (.exists (clojure.java.io/file f))
                                   (clojure.string/includes? (slurp f) "fhir.local:host-gateway")))]
           (when-not (.exists (clojure.java.io/file "inferno-test-kit"))
             (println "Cloning us-core-test-kit...")
             (shell "git" "clone" "https://github.com/inferno-framework/us-core-test-kit" "inferno-test-kit"))
           ;; Ensure rootCA.pem exists *before* any container start: the compose patch
           ;; bind-mounts ./rootCA.pem into the inferno/worker containers, and Podman
           ;; will silently create an empty directory at the bind source if the file is
           ;; missing -- which then renders the in-container path unreadable as a cert,
           ;; making every Ruby fhir_client TLS handshake fail. Recover from that case
           ;; by removing any pre-existing stub before copying.
           (when (and (.exists rootca-file) (.isDirectory rootca-file))
             (println "Removing stub rootCA.pem directory left by Podman bind-mount...")
             (shell "rm" "-rf" (.getPath rootca-file)))
           (when-not (.isFile rootca-file)
             (let [caroot (clojure.string/trim (:out (shell {:out :string} "mkcert" "-CAROOT")))]
               (println "Copying mkcert rootCA.pem into inferno-test-kit/ ...")
               (clojure.java.io/copy (clojure.java.io/file caroot "rootCA.pem") rootca-file)))
           (if (and (patched? compose-file) (patched? bg-file))
             (println "Inferno test kit already set up and patched -- skipping.")
             (do
               (println "Running inferno setup script...")
               (shell {:dir "inferno-test-kit"} "./setup.sh")
               (when (.exists (clojure.java.io/file "inferno-test-kit/data/redis/.keep"))
                 (println "Removing redis .keep file to allow permission fixes...")
                 (clojure.java.io/delete-file "inferno-test-kit/data/redis/.keep" true))
               (println "Patching docker-compose files...")
               (let [compose     (yaml/parse-string (slurp compose-file))
                     extra-hosts ["host.docker.internal:host-gateway"
                                  "fhir.local:host-gateway"]
                     ssl-env     ["SSL_CERT_FILE=/opt/inferno/rootCA.pem"]
                     patch-svc   (fn [svc]
                                   (-> svc
                                       (assoc :extra_hosts extra-hosts)
                                       (update :volumes (fnil conj []) "./rootCA.pem:/opt/inferno/rootCA.pem")
                                       (update :environment (fnil into []) ssl-env)))
                     patched     (-> compose
                                     (update-in [:services :inferno] patch-svc)
                                     (update-in [:services :worker] patch-svc)
                                     (assoc-in [:services :nginx :ports] ["8080:80"]))]
                 (spit compose-file (yaml/generate-string patched :dumper-options {:flow-style :block}))
                 (println "  docker-compose.yml patched."))
               (let [bg      (yaml/parse-string (slurp bg-file))
                     patched (assoc-in bg [:services :nginx :ports] ["8080:80"])]
                 (spit bg-file (yaml/generate-string patched :dumper-options {:flow-style :block}))
                 (println "  docker-compose.background.yml patched.")))))}

  inferno-run
  {:doc "Runs the Inferno Test Kit suite locally"
   :depends [inferno-setup]
   :task (shell {:dir "inferno-test-kit"} "./run.sh")}

  inferno-check
  {:doc "Smoke-test: checks that Inferno containers are healthy and the FHIR server responds to /metadata. Fast (~5s), no full test run."
   :depends [setup inferno-setup]
   :requires ([server.inferno-runner :as runner])
   :task (runner/check!)}

  inferno-test
  {:doc "Runs the Inferno CLI executor dynamically using Babashka."
   :depends [generate-uscore setup inferno-setup]
   :requires ([server.inferno-runner :as runner])
   :task (runner/run-check!)}

  generate-uscore
  {:doc "Generates Malli schema packages (r4b, xver, fhir-extensions, sdc, uscore8) from FHIR StructureDefinitions. Pass --force to regenerate when output already exists."
   :task (let [force?     (some #{"--force"} *command-line-args*)
               output-dir (clojure.java.io/file "fhir/malli/uscore8/src")]
           (if (and (.exists output-dir) (not force?))
             (println "fhir/malli/uscore8/src already exists -- skipping. Pass --force to regenerate.")
             (do
               (println "Ensuring target/staging/src exists...")
               (.mkdirs (clojure.java.io/file "fhir-defintions-to-malli/target/staging/src"))
               (println "Generating Malli schemas (this can take a few minutes)...")
               (shell {:dir "fhir-defintions-to-malli"}
                      "clj" "-X" "com.breezeehr.main/generate-uscore!"))))}

  inferno-down
  {:doc "Stops the Inferno docker instances"
   :task (if (.exists (clojure.java.io/file "inferno-test-kit/docker-compose.yml"))
           (shell {:dir "inferno-test-kit"} "docker" "compose" "down")
           (println "inferno-test-kit not present -- nothing to stop."))}}}
